PORT=8787
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOG_LEVEL=info

# When true, reject any operator model tag containing :cloud.
# The operator coordinates the session and sees raw workspace content;
# keep it local unless you explicitly opt out.
ENFORCE_LOCAL_OPERATOR=false

# Default-on anonymization of outbound writer/critic prompts.
# Client can override per-session. See server/anonymizer.ts for patterns.
ANONYMIZE_OUTBOUND=true

# Extra literal strings (comma-separated) to scrub from outbound prompts.
# ANONYMIZE_PATTERNS=Project Apollo,internal-host.corp

# Optional path to a JSON file of extra cloud model catalog entries.
# Each entry: {"tag":"...", "country":"...", "maker":"...", "abliterated":false}
# Merged into /api/catalog on top of the bundled curated list.
# CLOUD_CATALOG_PATH=./my-catalog.json
